{% extends 'base.html.twig' %}

{% block title %}➕ Modifier tâche{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Modifier tâche</h1>

    {# Messages flash #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {# FORMULAIRE COMPLET #}
    {{ form_start(form, {attr: {'data-turbo': 'false', class: 'needs-validation', novalidate: 'novalidate'}}) }}

        <div class="mb-3">
            {{ form_label(form.title) }}
            {{ form_widget(form.title, {attr: {class: 'form-control', placeholder: 'Que dois-je faire ?'}}) }}
            {{ form_help(form.title) }}
            {% for message in app.flashes('error') %}
                {% for error in form.title.vars.errors %}
                    <div style="color: red;">{{ error.message }}</div>
                {% endfor %}
            {% endfor %}
        </div>

        <div class="mb-3">
            {{ form_label(form.description) }}
            {{ form_widget(form.description, {attr: {class: 'form-control', rows: 3, placeholder: 'Détails...'}}) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.dueDate) }}
            {{ form_widget(form.dueDate, {attr: {class: 'form-control', type: 'datetime-local'}}) }}
        </div>

        <div class="form-check mb-3">
            {{ form_widget(form.isDone, {attr: {class: 'form-check-input'}}) }}
            {{ form_label(form.isDone, null, {label_attr: {class: 'form-check-label'}}) }}
        </div>

        <div class="mb-3">
            {{ form_label(form.priority, null, {label_attr: {class: 'form-check-label'}}) }}
        </div>
        <div class="d-flex gap-4 mb-3">
            {% for priority in form.priority %}
                <div class="d-flex gap-2">
                    {{ form_widget(priority, {
                                    attr: {
                                        class: 'form-check-input me-2 peer',
                                    },
                                }) }}
                    {{ form_label(priority, null, {
                                    label_attr: {
                                        class: 'form-check-label peer-checked:bg-primary peer-checked:text-white priority-badge px-4 py-2 rounded-3 fw-semibold border transition-all ' ~ priority.vars.value,
                                        for: priority.vars.id,
                                    },
                                }) }}
                </div>
            {% endfor %}
        </div>

        {# BOUTONS ! #}
        <div class="d-grid gap-4 d-md-flex justify-content-md-start" >
            <button type="submit" class="btn btn-success btn-lg" }>
                💾 Modifier la tâche
            </button>
            <a href="{{ path('app_todo') }}" class="btn btn-secondary d-flex align-items-center">
                ❌ Annuler
            </a>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}
